{
  "info": {
    "name": "Distributed Document Search Service",
    "_postman_id": "5d6d68f8-0dc0-4e89-aa2e-4a8f5965e6b1",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "tenantId",
      "value": "tenant-a"
    },
    {
      "key": "documentId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Create Document",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "X-Tenant-ID",
            "value": "{{tenantId}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\\n  \"title\": \"Distributed systems notes\",\\n  \"content\": \"Kafka, Redis, Elasticsearch, multi-tenancy, and eventual consistency.\"\\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/documents",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "documents"
          ]
        }
      }
    },
    {
      "name": "Get Document",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "X-Tenant-ID",
            "value": "{{tenantId}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/documents/{{documentId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "documents",
            "{{documentId}}"
          ]
        }
      }
    },
    {
      "name": "Search Documents",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "X-Tenant-ID",
            "value": "{{tenantId}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/search?q=distributed&size=10",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "search"
          ],
          "query": [
            {
              "key": "q",
              "value": "distributed"
            },
            {
              "key": "size",
              "value": "10"
            }
          ]
        }
      }
    },
    {
      "name": "Delete Document",
      "request": {
        "method": "DELETE",
        "header": [
          {
            "key": "X-Tenant-ID",
            "value": "{{tenantId}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/documents/{{documentId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "documents",
            "{{documentId}}"
          ]
        }
      }
    },
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/health",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "health"
          ]
        }
      }
    }
  ]
}